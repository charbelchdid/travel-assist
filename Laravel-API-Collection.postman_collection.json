{
  "info": {
    "name": "Laravel API with Custom JWT Auth",
    "description": "Complete API collection for Laravel application with custom JWT authentication integrated with external service (https://testbackerp.teljoy.io)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "workflowId",
      "value": "",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "",
      "type": "string"
    },
    {
      "key": "pageCode",
      "value": "Permissions",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.token) {",
                  "        pm.collectionVariables.set('authToken', response.token);",
                  "        console.log('Token saved to collection variables');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"MY_USERNAME\",\n    \"password\": \"MY_PASSWORD\",\n    \"device_id\": \"postman-client\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Authenticate user with external service. Credentials are base64 encoded and sent to https://testbackerp.teljoy.io/public/login/jwt"
          }
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/validate",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "validate"]
            },
            "description": "Validate if the current JWT token is still valid"
          }
        },
        {
          "name": "Login (Cookie)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"MY_USERNAME\",\n    \"password\": \"MY_PASSWORD\",\n    \"device_id\": \"postman-client\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login/cookie",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login", "cookie"]
            },
            "description": "Cookie-based login. Sets HttpOnly cookie `jwt_token` and a JS-readable `is_authenticated` cookie. Postman will store cookies per-domain."
          }
        },
        {
          "name": "Check Auth (Cookie)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/check",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "check"]
            },
            "description": "Cookie auth status check. Validates `jwt_token` cookie and clears cookies if invalid/expired."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Logout user (client-side token removal, can be extended for token blacklisting)"
          }
        }
      ],
      "description": "Authentication endpoints for JWT token management"
    },
    {
      "name": "User Management",
      "item": [
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/profile",
              "host": ["{{baseUrl}}"],
              "path": ["user", "profile"]
            },
            "description": "Get current authenticated user's profile information"
          }
