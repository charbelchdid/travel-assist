        {
          "name": "Update User Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"phone\": \"+1234567890\",\n    \"preferences\": {\n        \"language\": \"en\",\n        \"timezone\": \"UTC\",\n        \"notifications\": true\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/profile",
              "host": ["{{baseUrl}}"],
              "path": ["user", "profile"]
            },
            "description": "Update current user's profile information"
          }
        },
        {
          "name": "Get Activity Log",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/activity?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["user", "activity"],
              "query": [
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Number of activity records to return"
                }
              ]
            },
            "description": "Get user's activity log history"
          }
        },
        {
          "name": "Get Myself",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/myself",
              "host": ["{{baseUrl}}"],
              "path": ["myself"]
            },
            "description": "Alternative user info endpoint (compatible with external-service-like response format)"
          }
        }
      ],
      "description": "User profile and account management endpoints"
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get Products List",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?per_page=15&search=",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                {
                  "key": "per_page",
                  "value": "15",
                  "description": "Number of items per page"
                },
                {
                  "key": "search",
                  "value": "",
                  "description": "Search term for filtering products"
                }
              ]
            },
            "description": "Get paginated list of products with optional search"
          }
        },
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    const r = pm.response.json();",
                  "    if (r && r.data && r.data.id) {",
                  "        pm.collectionVariables.set('productId', String(r.data.id));",
                  "        console.log('productId saved to collection variables:', r.data.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"New Product\",\n    \"price\": 99.99,\n    \"stock\": 100,\n    \"category\": \"Electronics\",\n    \"description\": \"Product description here\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            },
            "description": "Create a new product"
          }
        },
        {
          "name": "Get Product Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            },
            "description": "Get detailed information about a specific product"
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Updated Product Name\",\n    \"price\": 129.99,\n    \"stock\": 75,\n    \"category\": \"Electronics\",\n    \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            },
            "description": "Update an existing product"
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            },
            "description": "Delete a product by ID"
          }
        },
        {
          "name": "Get Product Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/categories/list",
              "host": ["{{baseUrl}}"],
              "path": ["products", "categories", "list"]
            },
            "description": "Get list of all product categories"
          }
        }
      ],
      "description": "Product management endpoints"
    },
